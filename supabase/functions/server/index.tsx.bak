import { Hono } from "npm:hono";
import { cors } from "npm:hono/cors";
import { logger } from "npm:hono/logger";
import { createClient } from "npm:@supabase/supabase-js@2";
import * as kv from "./kv_store.tsx";

const app = new Hono();
app.use('*', logger(console.log));
app.use("/*", cors({ origin: "*", allowHeaders: ["Content-Type", "Authorization", "X-Admin-Token"], allowMethods: ["GET", "POST", "PUT", "DELETE", "OPTIONS"], exposeHeaders: ["Content-Length"], maxAge: 600 }));

const db = createClient(
  Deno.env.get('SUPABASE_URL')!,
  Deno.env.get('SUPABASE_SERVICE_ROLE_KEY')!,
);
const MEDIA_BUCKET = 'make-ea36795c-media';

// ─── TYPES ───
interface Product { id: string; name_fr: string; name_ar: string; description_fr: string; description_ar: string; price: number; sale_price?: number; images: string[]; video_url?: string; category_id: string; stock: number; is_featured: boolean; is_new: boolean; is_best_seller: boolean; is_promo: boolean; is_active: boolean; show_on_homepage: boolean; show_in_best_sellers: boolean; show_in_new_arrivals: boolean; show_in_promotions: boolean; show_in_cartables: boolean; show_in_trousses: boolean; show_in_school_supplies: boolean; sort_order: number; created_at: string; updated_at: string; }
interface Category { id: string; name_fr: string; name_ar: string; slug: string; image: string; order: number; is_active: boolean; }
interface Order { id: string; order_number: string; customer_name: string; customer_phone: string; customer_email: string; customer_address: string; customer_wilaya: string; items: any[]; subtotal: number; shipping: number; total: number; payment_method: string; delivery_type: string; status: string; notes: string; created_at: string; updated_at: string; }
interface WholesaleRequest { id: string; company_name: string; contact_name: string; phone: string; email: string; wilaya: string; message: string; status: string; created_at: string; }
interface Banner { id: string; title_fr: string; title_ar: string; subtitle_fr: string; subtitle_ar: string; cta_fr: string; cta_ar: string; image: string; link: string; is_active: boolean; order: number; }
interface ThemeSettings { primary_color: string; accent_color: string; bg_color: string; font_heading: string; font_body: string; button_radius: string; show_featured: boolean; show_new_arrivals: boolean; show_best_sellers: boolean; show_wholesale_section: boolean; show_testimonials: boolean; logo_text: string; logo_subtitle: string; }
interface SiteContent { about_fr: string; about_ar: string; address: string; phone: string; email: string; working_hours: string; facebook: string; instagram: string; whatsapp: string; map_embed: string; faq: any[]; }
interface MediaFile { id: string; filename: string; path: string; url: string; content_type: string; size: number; created_at: string; }

// ─── HELPERS ───
function uid() { return Date.now().toString(36) + Math.random().toString(36).slice(2); }
function respond(c: any, data: any, status = 200) { return c.json(data, status); }
function errRes(c: any, msg: string, status = 500) { console.log('ERROR:', msg); return c.json({ error: msg }, status); }

// ─── KV helpers ───
async function getList(prefix: string): Promise<string[]> {
  const val = await kv.get(`${prefix}:list`);
  return val ? JSON.parse(val) : [];
}
async function addToList(prefix: string, id: string) {
  const list = await getList(prefix);
  if (!list.includes(id)) { list.push(id); await kv.set(`${prefix}:list`, JSON.stringify(list)); }
}
async function removeFromList(prefix: string, id: string) {
  let list = await getList(prefix);
  list = list.filter(i => i !== id);
  await kv.set(`${prefix}:list`, JSON.stringify(list));
}
async function getAllKV<T>(prefix: string): Promise<T[]> {
  const ids = await getList(prefix);
  if (!ids.length) return [];
  const items = await Promise.all(ids.map(id => kv.get(`${prefix}:data:${id}`)));
  return items.filter(Boolean).map(i => JSON.parse(i!));
}
async function getOneKV<T>(prefix: string, id: string): Promise<T | null> {
  const val = await kv.get(`${prefix}:data:${id}`);
  return val ? JSON.parse(val) : null;
}
async function setOneKV(prefix: string, id: string, data: any) {
  await kv.set(`${prefix}:data:${id}`, JSON.stringify(data));
  await addToList(prefix, id);
}
async function delOneKV(prefix: string, id: string) {
  await kv.del(`${prefix}:data:${id}`);
  await removeFromList(prefix, id);
}

// ─── DB detection: checks ALL required tables exist ───
let _useDB: boolean | null = null;
async function useDB(): Promise<boolean> {
  if (_useDB !== null) return _useDB;
  try {
    // Check that BOTH products and product_images exist (full schema required)
    const [r1, r2] = await Promise.all([
      db.from('products').select('id').limit(1),
      db.from('product_images').select('id').limit(1),
    ]);
    _useDB = !r1.error && !r2.error;
    console.log(_useDB ? '✅ DB mode: Supabase tables' : '⚠️ DB mode: KV fallback (run SQL migration first)');
  } catch {
    _useDB = false;
    console.log('⚠️ DB check failed, using KV fallback');
  }
  return _useDB;
}

// ─── Storage setup ───
async function setupStorage() {
  try {
    const { data: buckets } = await db.storage.listBuckets();
    if (!buckets?.some((b: any) => b.name === MEDIA_BUCKET)) {
      await db.storage.createBucket(MEDIA_BUCKET, { public: true, fileSizeLimit: 52428800 });
    }
  } catch (e) { console.log('Storage setup error:', e); }
}

