app.get("/make-server-ea36795c/homepage-config", async (c) => {
  try {
    if (await useDB()) {
      try {
        const { data, error } = await db.from('homepage_sections').select('*').order('sort_order', { ascending: true });
        if (!error && data && data.length > 0) {
          const config: any = { sections_order: [] };
          for (const section of data) {
            config[section.section_key] = { enabled: section.is_enabled, title_fr: section.title_fr || '', title_ar: section.title_ar || '', ...(section.config || {}) };
            config.sections_order.push(section.section_key);
          }
          return respond(c, { config });
        }
      } catch (e) { console.log('DB homepage config failed, using KV:', e); }
    }
    const val = await kv.get("homepage:config");
    return respond(c, { config: val ? { ...DEFAULT_HP, ...JSON.parse(val) } : DEFAULT_HP });
  } catch (e) { return errRes(c, `Homepage config error: ${e}`); }
});

app.put("/make-server-ea36795c/homepage-config", async (c) => {
  try {
    if (!await isAdmin(c)) return errRes(c, "Unauthorized", 401);
    const body = await c.req.json();
    if (await useDB()) {
      try {
        for (const [key, value] of Object.entries(body)) {
          if (key === 'sections_order' || typeof value !== 'object' || value === null) continue;
          const section = value as any;
          const updates: any = {};
          if (section.enabled !== undefined) updates.is_enabled = section.enabled;
          if (section.title_fr !== undefined) updates.title_fr = section.title_fr;
          if (section.title_ar !== undefined) updates.title_ar = section.title_ar;
          const { enabled, title_fr, title_ar, ...extra } = section;
          if (Object.keys(extra).length > 0) updates.config = extra;
          await db.from('homepage_sections').update(updates).eq('section_key', key);
        }
        if (Array.isArray(body.sections_order)) {
          for (let i = 0; i < body.sections_order.length; i++) await db.from('homepage_sections').update({ sort_order: i + 1 }).eq('section_key', body.sections_order[i]);
        }
        return respond(c, { success: true });
      } catch (e) { console.log('DB update homepage failed, using KV:', e); }
    }
    const current = await kv.get("homepage:config");
    await kv.set("homepage:config", JSON.stringify({ ...(current ? JSON.parse(current) : DEFAULT_HP), ...body }));
    return respond(c, { success: true });
  } catch (e) { return errRes(c, `Update homepage config error: ${e}`); }
});

// ═══════════════ CONTENT ═══════════════
app.get("/make-server-ea36795c/content", async (c) => {
  try {
    if (await useDB()) {
      try {
        const { data, error } = await db.from('store_settings').select('key, value');
        if (!error && data && data.length > 0) {
          const content: any = {};
          for (const row of data) {
            if (row.key === 'general' || row.key === 'social') Object.assign(content, row.value);
            else content[row.key] = typeof row.value === 'string' ? row.value : row.value;
          }
          return respond(c, { content });
        }
      } catch (e) { console.log('DB content failed, using KV:', e); }
    }
    const val = await kv.get("content:data");
    return respond(c, { content: val ? JSON.parse(val) : {} });
  } catch (e) { return errRes(c, `Get content error: ${e}`); }
});

app.put("/make-server-ea36795c/content", async (c) => {
  try {
    if (!await isAdmin(c)) return errRes(c, "Unauthorized", 401);
    const body = await c.req.json();
    if (await useDB()) {
      try {
        const generalFields = ['phone','email','whatsapp','address','store_name','store_subtitle','currency','country','shipping_fee','free_shipping_threshold'];
        const socialFields = ['facebook','instagram','tiktok','youtube'];
        const gU: any = {}, sU: any = {};
        for (const [k, v] of Object.entries(body)) {
          if (generalFields.includes(k)) gU[k] = v;
          else if (socialFields.includes(k)) sU[k] = v;
          else if (['about_fr','about_ar','working_hours','map_embed','faq'].includes(k)) await db.from('store_settings').upsert({ key: k, value: k === 'faq' ? v : JSON.stringify(v) });
        }
        if (Object.keys(gU).length > 0) { const { data: ex } = await db.from('store_settings').select('value').eq('key', 'general').single(); await db.from('store_settings').upsert({ key: 'general', value: { ...(ex?.value || {}), ...gU } }); }
        if (Object.keys(sU).length > 0) { const { data: ex } = await db.from('store_settings').select('value').eq('key', 'social').single(); await db.from('store_settings').upsert({ key: 'social', value: { ...(ex?.value || {}), ...sU } }); }
        return respond(c, { success: true });
      } catch (e) { console.log('DB update content failed, using KV:', e); }
    }
    const current = await kv.get("content:data");
    await kv.set("content:data", JSON.stringify({ ...(current ? JSON.parse(current) : {}), ...body }));
    return respond(c, { success: true });
  } catch (e) { return errRes(c, `Update content error: ${e}`); }
});

