      try { const { error } = await db.from('products').delete().eq('id', id); if (!error) return respond(c, { success: true }); } catch { /* fallthrough */ }
    }
    await delOneKV("products", id);
    return respond(c, { success: true });
  } catch (e) { return errRes(c, `Delete product error: ${e}`); }
});

