// ═══════════════ ORDERS ═══════════════
app.get("/make-server-ea36795c/orders", async (c) => {
  try {
    if (!await isAdmin(c)) return errRes(c, "Unauthorized", 401);
    if (await useDB()) {
      try {
        const { data, error } = await db.from('orders').select('*').order('created_at', { ascending: false });
        if (!error) {
          // Fetch items separately
          const orderIds = (data || []).map((o: any) => o.id);
          let itemsByOrder: Record<string, any[]> = {};
          if (orderIds.length > 0) {
            try {
              const { data: items } = await db.from('order_items').select('*').in('order_id', orderIds);
              for (const item of (items || [])) {
                if (!itemsByOrder[item.order_id]) itemsByOrder[item.order_id] = [];
                itemsByOrder[item.order_id].push(item);
              }
            } catch { /* ignore */ }
          }
          const orders = (data || []).map((o: any) => ({ ...o, items: itemsByOrder[o.id] || [] }));
          return respond(c, { orders, total: orders.length });
        }
      } catch (e) { console.log('DB orders failed, using KV:', e); }
    }
    const orders = await getAllKV<Order>("orders");
    orders.sort((a, b) => new Date(b.created_at).getTime() - new Date(a.created_at).getTime());
    return respond(c, { orders, total: orders.length });
  } catch (e) { return errRes(c, `Orders list error: ${e}`); }
});

app.get("/make-server-ea36795c/orders/:id", async (c) => {
  try {
    const id = c.req.param("id");
    if (await useDB()) {
      try {
        const { data, error } = await db.from('orders').select('*').eq('id', id).single();
        if (!error && data) {
          let items: any[] = [];
          try { const { data: it } = await db.from('order_items').select('*').eq('order_id', id); items = it || []; } catch { /* ignore */ }
          return respond(c, { order: { ...data, items } });
        }
      } catch (e) { console.log('DB get order failed:', e); }
    }
    const order = await getOneKV<Order>("orders", id);
    if (!order) return errRes(c, "Order not found", 404);
    return respond(c, { order });
  } catch (e) { return errRes(c, `Get order error: ${e}`); }
});

app.post("/make-server-ea36795c/orders", async (c) => {
  try {
    const body = await c.req.json();
    const orderNum = "VK-" + Date.now().toString().slice(-8);
    const now = new Date().toISOString();

    if (await useDB()) {
      try {
        let customerId = null;
        if (body.customer_phone) {
          const phone = String(body.customer_phone).replace(/\s/g, '');
          const { data: existing } = await db.from('customers').select('id, total_spent, total_orders').eq('phone', phone).single();
          if (existing) {
            customerId = existing.id;
            await db.from('customers').update({ total_spent: (existing.total_spent || 0) + Number(body.total || 0), total_orders: (existing.total_orders || 0) + 1 }).eq('id', existing.id);
          } else {
            const { data: newC } = await db.from('customers').insert({ name: body.customer_name || '', phone, email: body.customer_email || '', wilaya: body.customer_wilaya || '', total_spent: Number(body.total || 0), total_orders: 1 }).select('id').single();
            if (newC) customerId = newC.id;
          }
        }
        const { data: order, error } = await db.from('orders').insert({ order_number: orderNum, customer_id: customerId, customer_name: body.customer_name || '', customer_phone: body.customer_phone || '', customer_email: body.customer_email || '', customer_address: body.customer_address || '', customer_wilaya: body.customer_wilaya || '', subtotal: Number(body.subtotal) || 0, shipping: Number(body.shipping) || 0, total: Number(body.total) || 0, payment_method: body.payment_method || 'cash_on_delivery', delivery_type: body.delivery_type || 'delivery', status: 'new', notes: body.notes || '' }).select().single();
        if (error) throw new Error(error.message);
        const items = body.items || [];
        if (items.length > 0 && order) {
          try {
            await db.from('order_items').insert(items.map((item: any) => ({ order_id: order.id, product_id: item.product_id || null, product_name_fr: item.name_fr || item.name || '', product_name_ar: item.name_ar || '', product_image: item.image || (item.images?.[0]) || '', unit_price: Number(item.price) || 0, quantity: Number(item.qty || item.quantity) || 1, total: (Number(item.price) || 0) * (Number(item.qty || item.quantity) || 1) })));
          } catch { /* ignore */ }
          for (const item of items) {
            if (item.product_id) {
              try { const { data: prod } = await db.from('products').select('stock').eq('id', item.product_id).single(); if (prod) await db.from('products').update({ stock: Math.max(0, prod.stock - (item.qty || item.quantity || 1)) }).eq('id', item.product_id); } catch { /* ignore */ }
            }
          }
        }
        return respond(c, { order: { ...order, items } }, 201);
      } catch (e) { console.log('DB create order failed, using KV:', e); }
    }

    const id = "ord-" + uid();
    const order: Order = { id, order_number: orderNum, customer_name: body.customer_name || "", customer_phone: body.customer_phone || "", customer_email: body.customer_email || "", customer_address: body.customer_address || "", customer_wilaya: body.customer_wilaya || "", items: body.items || [], subtotal: Number(body.subtotal) || 0, shipping: Number(body.shipping) || 0, total: Number(body.total) || 0, payment_method: body.payment_method || "cash_on_delivery", delivery_type: body.delivery_type || "delivery", status: "new", notes: body.notes || "", created_at: now, updated_at: now };
    await setOneKV("orders", id, order);
    const custId = "cust-" + String(body.customer_phone || '').replace(/\D/g, "");
    const existingCust = await getOneKV<any>("customers", custId);
    await setOneKV("customers", custId, existingCust ? { ...existingCust, orders: [...(existingCust.orders || []), id], total_spent: (existingCust.total_spent || 0) + order.total, updated_at: now } : { id: custId, name: body.customer_name, phone: body.customer_phone, email: body.customer_email || "", wilaya: body.customer_wilaya || "", orders: [id], total_spent: order.total, type: "retail", created_at: now, updated_at: now });
    for (const item of (body.items || [])) {
      const prod = await getOneKV<Product>("products", item.product_id);
      if (prod) await setOneKV("products", prod.id, { ...prod, stock: Math.max(0, prod.stock - (item.qty || 1)) });
    }
    return respond(c, { order }, 201);
  } catch (e) { return errRes(c, `Create order error: ${e}`); }
});

app.put("/make-server-ea36795c/orders/:id", async (c) => {
  try {
    if (!await isAdmin(c)) return errRes(c, "Unauthorized", 401);
